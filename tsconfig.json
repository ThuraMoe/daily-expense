{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node", // or "nodenext" for strict ESM environment
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true, // This makes noImplicitAny as true
    "lib": [
      "esnext",
      "dom"
    ],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
  }
}